---
const currentYear = new Date().getFullYear();
---
<footer style="background-color: #7a7480;" class="border-t border-[#69636e] py-6 mt-auto text-white">
  <div class="max-w-5xl mx-auto px-6">
    
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pb-4 border-b border-white/10">
      <div class="text-center md:text-left">
        <span class="text-sm font-light tracking-widest uppercase block">Elevate With Andy</span>
        <span class="text-[10px] tracking-wider text-neutral-200 uppercase block mt-0.5">Resilience in Motion</span>
      </div>
      
      <nav class="flex flex-wrap justify-center gap-6 text-[10px] tracking-widest uppercase font-semibold text-neutral-200">
        <!-- 🌟 UPDATED: Core link set to your custom handle layout -->
        <a href="https://www.youtube.com/@ElevatewithAndy" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
          YouTube Channel
        </a>
        <a href="/videos" class="hover:text-white transition-colors">Videos</a>
        <a href="/blog" class="hover:text-white transition-colors">Notebook</a>
        <a href="/gear" class="hover:text-white transition-colors">Recommended Gear</a>
      </nav>
    </div>

    <div class="pt-4 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] text-neutral-300 font-light tracking-wide text-center md:text-left">
      <p class="whitespace-nowrap">© {currentYear} Elevate With Andy. All Rights Reserved.</p>
      <p class="max-w-xl md:text-right leading-relaxed italic text-neutral-200/80">
        As an Amazon Associate, Elevate With Andy earns from qualifying purchases made through recommended gear links.
      </p>
    </div>

  </div>
</footer>
