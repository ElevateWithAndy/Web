---
---
<header class="sticky top-0 z-50 shadow-sm">
  <!-- Top Tier: Signature Grey Background with White Text -->
  <div style="background-color: #7a7480;" class="border-b border-[#69636e]">
    <!-- The 'relative' class here anchors the floating desktop menu card correctly -->
    <div class="max-w-5xl mx-auto px-6 pt-4 pb-4 flex flex-row justify-between items-center relative">
      
      <!-- Brand Logo Block -->
      <a href="/" class="group text-left z-50">
        <span class="text-xl font-light tracking-widest text-white uppercase block">Elevate With Andy</span>
        <span class="text-xs tracking-wider text-neutral-200 font-medium uppercase mt-0.5 block">Resilience in Motion</span>
      </a>
      
      <!-- Universal Hamburger Toggle Button -->
      <button 
        id="menu-toggle" 
        aria-label="Toggle Navigation Menu" 
        class="flex flex-col justify-center items-center w-8 h-8 gap-1.5 z-50 bg-transparent border-0 cursor-pointer focus:outline-none"
      >
        <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="line1"></span>
        <span class="w-6 h-0.5 bg-white transition-all duration-300" id="line2"></span>
        <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="line3"></span>
      </button>
      
      <!-- Navigation Menu Dropdown (Full width on mobile, compact right-aligned card on desktop) -->
      <nav 
        id="nav-menu" 
        class="hidden flex-col items-center gap-y-5 text-center text-sm tracking-wide uppercase font-medium text-white/90
               absolute top-full left-0 w-full bg-[#7a7480] pb-6 pt-6 border-b border-[#69636e] z-40 shadow-md
               sm:left-auto sm:right-6 sm:w-64 sm:rounded-lg sm:border sm:mt-2"
      >
        <a href="/videos" class="w-full hover:text-white hover:bg-white/5 py-2 transition-colors">Videos</a>
        <!-- 🌟 Locked In: Direct path routing to your Living Notebook -->
        <a href="/LivingNotebook" class="w-full hover:text-white hover:bg-white/5 py-2 transition-colors">Living Notebook</a>
        <a href="/gear" class="w-full hover:text-white hover:bg-white/5 py-2 transition-colors">Recommended Gear</a>
      </nav>
      
    </div>
  </div>

  <!-- Bottom Tier: Matches Page Canvas (#fcfbfc) with Centered Signature Grey Text -->
  <div class="bg-[#fcfbfc] border-b border-neutral-100 py-2.5">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <span class="text-[10px] md:text-xs font-light tracking-[0.2em] text-[#7a7480] uppercase inline-block">
        Functional Movement • Restorative Rituals • Integrated Connection
      </span>
    </div>
  </div>
</header>

<!-- Lightweight Interactive Vanilla JS Handler -->
<script>
  function initMenu() {
    const toggleBtn = document.getElementById('menu-toggle');
    const navMenu = document.getElementById('nav-menu');
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');

    if (toggleBtn && navMenu && line1 && line2 && line3) {
      toggleBtn.replaceWith(toggleBtn.cloneNode(true));
      const freshBtn = document.getElementById('menu-toggle');
      
      freshBtn?.addEventListener('click', () => {
        const isOpen = navMenu.classList.contains('hidden');
        
        if (isOpen) {
          navMenu.classList.remove('hidden');
          navMenu.classList.add('flex');
          
          line1.classList.add('rotate-45', 'translate-y-2');
          line2.classList.add('opacity-0', 'scale-0');
          line3.classList.add('-rotate-45', '-translate-y-2');
        } else {
          navMenu.classList.remove('flex');
          navMenu.classList.add('hidden');
          
          line1.classList.remove('rotate-45', 'translate-y-2');
          line2.classList.remove('opacity-0', 'scale-0');
          line3.classList.remove('-rotate-45', '-translate-y-2');
        }
      });
    }
  }

  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>
