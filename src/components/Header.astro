---
---
<!-- We add your signature grey here, and switch border colors to match -->
<header style="background-color: #7a7480;" class="border-b border-[#69636e] sticky top-0 z-50 shadow-sm">
  <div class="max-w-5xl mx-auto px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
    <a href="/" class="group text-center sm:text-left">
      <!-- Changed text colors to white and high-contrast light grey for readability -->
      <span class="text-xl font-light tracking-widest text-white uppercase block">Elevate With Andy</span>
      <span class="text-xs tracking-wider text-neutral-200 font-medium uppercase mt-0.5 block">Resilience in Motion</span>
    </a>
    <!-- Changed link navigation colors to pure white and subtle hover opacity shifts -->
    <nav class="flex flex-wrap justify-center items-center gap-x-8 gap-y-2 text-center text-sm tracking-wide uppercase font-medium text-white/90">
      <!-- Each link has 'w-full sm:w-auto' to stack cleanly on mobile but sit side-by-side on desktop -->
      <a href="/videos" class="w-full sm:w-auto block sm:inline hover:text-white transition-colors order-2 sm:order-none">Videos</a>
      <a href="/LivingNotebook" class="w-full sm:w-auto block sm:inline hover:text-white transition-colors order-1 sm:order-none">Blog</a>
      <a href="/gear" class="w-full sm:w-auto block sm:inline hover:text-white transition-colors order-3 sm:order-none">Recommended Gear</a>
    </nav>    
  </div>
  <!-- Bottom Tier: Matches Page Canvas (#fcfbfc) with Centered Signature Grey Text -->
  <div class="bg-[#fcfbfc] border-b border-neutral-100 py-2.5">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <span class="text-[10px] md:text-xs font-light tracking-[0.2em] text-[#7a7480] uppercase inline-block">
        Functional Movement • Restorative Rituals • Integrated Connection
      </span>
    </div>
  </div>
</header>
