---
import BaseLayout from '../layouts/BaseLayout.astro';

// 🌟 LOCKED IN: Your active Amazon Tracking ID parameter
const amazonTag = "elevatewit027-20"; 

const gearCategories = [
  {
    category: "Pilates & Core",
    items: [
      { name: "Premium Pilates Mat", desc: "1/2-Inch extra thick high-density foam to protect your spine during rolling exercises.", asin: "B07H9YVJ71" },
      { name: "Balanced Body Pilates Ring", desc: "14-inch flexible resistance ring with inner/outer padded grips for thigh tracking.", asin: "B00076MD8K" }
    ]
  },
  {
    category: "Functional Movement & Ballet",
    items: [
      { name: "High-Density Foam Roller", desc: "36-inch roller for myofascial release, thoracic spine mobility, and posture alignment.", asin: "B00X3MOWE0" },
      { name: "Professional Ballet Turning Board", desc: "Sturdy composite board to improve your spot, core engagement, and pirouette balance.", asin: "B019G7CPRE" }
    ]
  }
];
---
<BaseLayout title="Recommended Gear | Elevate With Andy">
  <main class="max-w-4xl mx-auto px-6 py-16">
    
    <!-- Editorial Page Intro -->
    <div class="text-center max-w-xl mx-auto mb-16">
      <h1 class="text-3xl font-light tracking-wide text-[#1e1b21] uppercase">Recommended Gear</h1>
      <p class="text-sm text-[#7a7480] mt-3 leading-relaxed font-light">
        Tools and props curated to build resilience, alignment, and strength. Products featured here are used directly in my classes.
      </p>
      <!-- Crucial Conspicuous FTC Legal Disclaimer Box -->
      <p class="text-[10px] text-neutral-400 italic mt-2">
        As an Amazon Associate, Elevate With Andy earns from qualifying purchases.
      </p>
    </div>

    <!-- Product Matrix Sections -->
    <div class="space-y-16">
      {gearCategories.map(cat => (
        <div>
          <h2 class="text-xs font-bold tracking-widest text-[#7a7480] uppercase border-b border-neutral-100 pb-2 mb-6">
            {cat.category}
          </h2>
          <div class="grid md:grid-cols-2 gap-8">
            {cat.items.map(item => (
              <div class="flex flex-col justify-between p-6 bg-[#fcfbfc] border border-neutral-100 rounded-lg hover:border-[#7a7480]/20 transition-all shadow-sm">
                <div>
                  <h3 class="font-normal text-base text-[#1e1b21] uppercase tracking-wide">{item.name}</h3>
                  <p class="text-sm text-[#7a7480] mt-2 leading-relaxed font-light">{item.desc}</p>
                </div>
                <div class="mt-6">
                  <!-- Completely safe direct link construction string layout -->
                  <a 
                    href={`https://amazon.com{item.asin}/?tag=${amazonTag}`}
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="inline-block w-full text-center text-xs font-semibold tracking-wider uppercase bg-[#1e1b21] hover:bg-[#7a7480] text-white py-3 px-4 rounded transition-colors"
                  >
                    View on Amazon
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>
