---
import BaseLayout from '../layouts/BaseLayout.astro';

// Your active Amazon Tracking ID parameter
const amazonTag = "elevatewit027-20"; 

const gearCategories = [
  {
    category: "Functional Movement Props",
    items: [
      { 
        name: "Franklin Method Ball Set", 
        desc: "Textured alignment balls specifically designed for deep myofascial release, improving proprioceptive bone feedback, and melting away pelvic and foot tension.", 
        asin: "B002YQRF1A"
      },
      { 
        name: "OPTP Franklin Method Fascia Roll", 
        desc: "A specialized, contoured roller engineered to comfortably cradle the limbs and spine, offering deep localized myofascial decompression and shoulder-rolling support.", 
        asin: "B00N26TZSW"
      },
      { 
        name: "OPTP Franklin Method Bands", 
        desc: "Premium, highly flexible resistance bands configured for dynamic alignment training, localized force redirection, and direct neuromuscular mapping feedback.", 
        asin: "B00FXTW2UY"
      },
      { 
        name: "TriggerPoint Grid Foam Roller", 
        desc: "Features a multi-density exterior grid pattern over a rigid hollow core to simulate a massage therapist's hands, safely expanding thoracic spine mobility.", 
        asin: "B004OEGNIU"
      },
      { 
        name: "Balanced Body Pilates Ring", 
        desc: "An ultra-durable 15-inch Ultra-Fit Circle fitted with dual-sided molded padding to safely map, track, and regulate inner/outer leg alignment and core connection.", 
        asin: "B002YQW3IU"
      },
      { 
        name: "Balanced Body Balance Pad", 
        desc: "A stable yet reactive high-density foam block canvas designed to challenge deep ankle stabilization, multi-planar balance networks, and deep pelvic control.", 
        asin: "B002YQY1SK"
      },
      { 
        name: "Balanced Body Pilates Arc", 
        desc: "An ergonomic three-in-one step barrel and spine corrector designed to unpack thoracic stiffness, assist lateral flexions, and cleanly scale lower abdominal engagement.", 
        asin: "B002XVSNRG"
      },
      { 
        name: "Balanced Body Pilates Mat", 
        desc: "An extra-thick, dense structural fitness mat engineered with premium cushioning to protect your spine base and joint pivots throughout complex rolling movement series.", 
        asin: "B009V29BQW"
      },
      { 
        name: "Balanced Body Magic Roller", 
        desc: "A highly resilient, full-length cylindrical roller built for fine balance tracking, deep postural correction, and supporting long-term structural core stability routines.", 
        asin: "B0D1V17XJF"
      },
      { 
        name: "Balanced Body Pilates Moon Box", 
        desc: "A rigid, upholstered wooden step block used to elevate the hips, stabilize seating postures, and correctly adjust height lines during advanced apparatus or mat setups.", 
        asin: "B00LONXKUO"
      },
      { 
        name: "Pilates Parasetter", 
        desc: "A specialized spinal alignment cradle built with dual-channel physical reliefs to eliminate vertical rib flaring and calm overactive paraspinal muscle tension.", 
        asin: "B07MVMB34K"
      }
    ]
  },
  {
    category: "Staying Organized on the Go",
    items: [
      { 
        name: "Travel Item Placeholder 1", 
        desc: "Replace this text with your custom travel recommendation overview. Describe how it keeps you balanced or organized on the go.", 
        asin: "B00REPLACE1"
      },
      { 
        name: "Travel Item Placeholder 2", 
        desc: "Replace this text with your next favorite travel pack or tool configuration.", 
        asin: "B00REPLACE2"
      }
    ]
  },
  {
    category: "D&D Essentials",
    items: [
      { 
        name: "D&D Item Placeholder 1", 
        desc: "Replace this text with details about your favorite Dungeons & Dragons tabletop gear, dice cases, adventure journals, or posture helpers for long campaign sessions.", 
        asin: "B00REPLACE3"
      },
      { 
        name: "D&D Item Placeholder 2", 
        desc: "Replace this text with your second campaign gear recommendation.", 
        asin: "B00REPLACE4"
      }
    ]
  }
];
---
<BaseLayout title="Recommended Gear | Elevate With Andy">
  <main class="max-w-5xl mx-auto px-6 py-16">
    
    <!-- Editorial Page Intro -->
    <div class="text-center max-w-xl mx-auto mb-16">
      <h1 class="text-3xl font-light tracking-wide text-[#1e1b21] uppercase">Recommended Gear</h1>
      <p class="text-sm text-[#7a7480] mt-3 leading-relaxed font-light">
        Tools and props curated to build resilience, alignment, and strength. Products featured here are used directly in my classes.
      </p>
      <!-- FTC Compliance Disclaimer Box -->
      <p class="text-[10px] text-neutral-400 italic mt-2">
        As an Amazon Associate, Elevate With Andy earns from qualifying purchases.
      </p>
    </div>

    <!-- Product Matrix Sections -->
    <div class="space-y-20">
      {gearCategories.map(cat => (
        <div>
          <h2 class="text-xs font-bold tracking-widest text-[#7a7480] uppercase border-b border-neutral-100 pb-2 mb-8">
            {cat.category}
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {cat.items.map(item => (
              <div class="flex flex-col justify-between bg-white border border-neutral-100 rounded-lg overflow-hidden hover:border-[#7a7480]/20 transition-all shadow-sm group">
                
                <!-- Live Product Image Container using safe ASIN-direct syndication -->
                <div class="bg-white h-48 p-6 flex items-center justify-center border-b border-neutral-50 relative">
                  {item.asin.includes("REPLACE") ? (
                    <div class="text-center text-[10px] uppercase font-medium tracking-wider text-neutral-300 border border-dashed border-neutral-200 rounded p-4">
                      Image coming soon
                    </div>
                  ) : (
                    <img 
                      src={`https://amazon.com{item.asin}.01._AC_SX300_.jpg`} 
                      alt={item.name}
                      loading="lazy"
                      class="max-h-full max-w-full object-contain mix-blend-multiply opacity-90 group-hover:opacity-100 transition-opacity duration-300"
                    />
                  )}
                </div>

                <div class="p-6 flex-grow flex flex-col justify-between bg-white">
                  <div>
                    <h3 class="font-normal text-base text-[#1e1b21] uppercase tracking-wide leading-snug">{item.name}</h3>
                    <p class="text-xs text-[#7a7480] mt-2 leading-relaxed font-light line-clamp-3">{item.desc}</p>
                  </div>
                  <div class="mt-6">
                    <a 
                      href={`https://amazon.com{item.asin}/?tag=${amazonTag}`}
                      target="_blank" 
                      rel="noopener noreferrer" 
                      class="inline-block w-full text-center text-xs font-semibold tracking-wider uppercase bg-[#1e1b21] hover:bg-[#7a7480] text-white py-3 px-4 rounded transition-colors"
                    >
                      View on Amazon
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>
