---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch the copy data from the JSON file mapping
const aboutEntry = await getEntry('about', 'index');
if (!aboutEntry) {
  throw new Error("Could not find content for 'src/content/about/about.json'");
}
const { title, meta, storyParagraphs, modalities, cta } = aboutEntry.data;
---

<BaseLayout title={title}>
  <main class="max-w-3xl mx-auto px-6 py-16">
    
    <!-- Hero Header Narrative -->
    <header class="text-center max-w-xl mx-auto mb-6">
      <span class="text-xs font-semibold tracking-[0.25em] text-[#7a7480] uppercase block mb-3">
        {meta.subtitle}
      </span>
      <h1 class="text-3xl font-light tracking-wide text-[#1e1b21] uppercase">
        {meta.heading}
      </h1>
      <div class="w-12 h-px bg-[#7a7480]/30 mx-auto mt-6"></div>
    </header>

    <!-- Editorial Core Story Content -->
    <article class="space-y-8 text-base text-[#1e1b21] font-light leading-relaxed">
      {storyParagraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </article>

    <!-- The Three Pillars Detail Shelves -->
    <section class="pt-10 pb-4 space-y-12">
      <h2 class="text-xs font-bold tracking-widest text-[#7a7480] uppercase border-b border-neutral-100 pb-2">
        {modalities.heading}
      </h2>
      
      <div class="space-y-8">
        {modalities.items.map((modality) => (
          <div>
            <h3 class="text-sm font-semibold text-[#1e1b21] uppercase tracking-wide">
              {modality.title}
            </h3>
            <p class="text-sm text-[#7a7480] font-light mt-2 leading-relaxed">
              {modality.descPart1}
              {modality.hasEmphasis && <em>{modality.emphasisText}</em>}
              {modality.descPart2}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Connect / Call to Action Block -->
    <section class="pt-8 pb-4 pt-12 border-t border-neutral-100 text-center">
      <a 
        href={cta.url} 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-xs font-semibold tracking-wider uppercase bg-[#1e1b21] hover:bg-[#7a7480] text-white px-6 py-3 rounded transition-colors shadow-sm inline-block"
      >
        {cta.text}
      </a>
    </section>

  </main>
</BaseLayout>
