---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch home page text content from the JSON entry
const homeEntry = await getEntry('home', 'index');
if (!homeEntry) {
  throw new Error("Could not find content for 'src/content/home/index.json'");
}

const { title, hero, foundations } = homeEntry.data;

// Fetch the 2 most recent LivingNotebook posts to feature at the bottom
// Uses 'livingNotebookCollection' to match your exact export key in config.ts
const rawPosts = await getCollection('livingNotebookCollection') || [];
const recentPosts = rawPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout title={title}>
  <!-- Section 1: Minimalist Hero Banner -->
  <section class="max-w-4xl mx-auto px-6 pt-10 pb-8 text-center">
    <h1 class="text-4xl md:text-5xl font-light tracking-wide text-[#1e1b21] uppercase leading-tight">
      {hero.headingLine1}<br class="hidden md:inline"/> {hero.headingLine2}
    </h1>
    <p class="text-base text-[#7a7480] mt-6 max-w-xl mx-auto font-light leading-relaxed">
      {hero.body}
    </p>
  </section>

  <!-- Section 2: Three Pillars Showcase -->
  <section class="bg-[#fcfbfc] border-y border-neutral-100 pt-12 pb-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-xs font-bold tracking-widest text-[#7a7480] uppercase text-center mb-12">
        {foundations.heading}
      </h2>
      
      <div class="grid md:grid-cols-3 gap-12">
        {foundations.pillars.map((pillar) => (
          <div class="text-center">
            <h3 class="text-lg font-medium text-[#1e1b21] mb-3">
              {pillar.title}
            </h3>
            <p class="text-sm text-[#7a7480] font-light leading-relaxed max-w-xs mx-auto">
              {pillar.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
