---
import Parser from 'rss-parser';
import BaseLayout from '../layouts/BaseLayout.astro';

const parser = new Parser();

// 1. UPDATE THESE: Replace with your actual YouTube Playlist IDs (the text after list=)
const playlists = [
  {
    name: "Pilates Cookies | Bite-Sized Resets",
    id: "PL-jCamkYihtuEjomINLE9siPYAxrijcPg",
    description: `Enjoy a Pilates Cookie — a bite-sized movement ritual to help you find feel-good ease and be where your feet are.  
    
    Through mindful movement, we change ourselves from the inside out. By using gravity as our free training tool—and occasionally bringing in small props for immediate feedback—we can quickly restore alignment, clear the mental clutter, and reset our entire state of being in just a few minutes. This is the power of continuously showing up, one bite-sized piece at a time.  
    
    This is why we elevate.  
    
    #PilatesCookies #BiteSizedRitual #BeWhereYourFeetAre #MindfulMovement #ElevateWithAndy`
  },
  {
    name: "Shadows & Stars: The Wild Experiment",
    id: "PL-jCamkYihtt3kq88Pfi1-ZlaBi0AOpO2",
    description: `Welcome to a space where thriving is a wild experiment.  
    
    This playlist explores creative projects and everyday habits that go way beyond just "moving well"—taking practices out of the studio and releasing them into real life. It’s where artistic endeavors and everyday play collide.  
    
    From deep-diving into D&D characters and digging in the yard, to hanging with furred and feathered friends... it’s all part of the practice.  
    
    This is where we find our feet in the dark together, walking amongst the shadows to find our stars.  
    
    #WildExperiment #CreativeWellBeing #EmbodiedLiving #DNDCommunity #ElevateWithAndy`
  }
];

// Fetch and unpack each playlist feed asynchronously
const structuredCategories = await Promise.all(
  playlists.map(async (pl) => {
    try {
      const feed = await parser.parseURL(`https://youtube.com/playlist?list={pl.id}`);
      
      const videos = feed.items.map(item => {
        const videoId = item.link ? item.link.split('v=')[1]?.split('&')[0] : '';
        return {
          title: item.title || 'Movement Session',
          youtubeUrl: item.link,
          thumbnail: videoId 
            ? `https://youtube.com{videoId}/maxresdefault.jpg` 
            : 'https://youtube.com'
        };
      }).slice(0, 3); // Limits the page to the 3 most recent videos per playlist

      return { name: pl.name, description: pl.description, videos };
    } catch (e) {
      console.error(`Error parsing playlist ${pl.name}:`, e);
      return { name: pl.name, description: pl.description, videos: [] };
    }
  })
);
---

<BaseLayout title="Movement Index | Elevate With Andy">
  <main class="max-w-5xl mx-auto px-6 py-16">
    
    <!-- Video Page Title Block -->
    <div class="text-center max-w-xl mx-auto mb-20">
      <h1 class="text-3xl font-light tracking-wide text-[#1e1b21] uppercase">On-Demand Practice</h1>
      <p class="text-sm text-[#7a7480] mt-3 font-light leading-relaxed">
        Sequences and training sets sorted by movement discipline.
      </p>
    </div>
    <!-- Playlist Section Divider Blocks -->
    <div class="space-y-24">
      {structuredCategories.map(category => (
        // 1. REMOVED the "category.videos.length > 0 &&" condition so it always shows
        <section>
          <!-- Title Bar Grouping -->
          <div class="border-b border-neutral-100 pb-4 mb-8">
            <h2 class="text-xs font-bold tracking-widest text-[#7a7480] uppercase">
              {category.name}
            </h2>
            <p class="text-xs text-[#7a7480] font-light mt-2 max-w-2xl leading-relaxed whitespace-pre-line">
              {category.description}
            </p>
          </div>
          
          <!-- 2. ADDED a conditional check inside the grid block -->
          {category.videos.length === 0 ? (
            // Minimalist placeholder for empty rows
            <div class="py-12 px-6 border border-dashed border-neutral-200 rounded-lg text-center max-w-sm">
              <p class="text-xs text-[#7a7480] font-light italic">
                New movement sequences coming soon to this collection.
              </p>
            </div>
          ) : (
            // Grid Matrix Display for active videos
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
              {category.videos.map(video => (
                <div class="group flex flex-col justify-between bg-white border border-neutral-100 rounded-lg p-4 shadow-sm hover:border-[#7a7480]/20 transition-all">
                  <div>
                    <div class="aspect-video w-full overflow-hidden bg-neutral-50 rounded mb-4">
                      <img 
                        src={video.thumbnail} 
                        alt={video.title} 
                        loading="lazy"
                        class="w-full h-full object-cover grayscale-[15%] group-hover:grayscale-0 transition-all duration-300"
                      />
                    </div>
                    <h3 class="font-normal text-base text-[#1e1b21] leading-snug line-clamp-2">{video.title}</h3>
                  </div>
                  <div class="mt-4 pt-3 border-t border-neutral-50">
                    <a 
                      href={video.youtubeUrl} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      class="text-xs font-semibold tracking-wider uppercase text-red-600 hover:text-red-700 inline-flex items-center gap-1 transition-colors"
                    >
                      Stream Practice 
                      <span class="text-sm font-normal">→</span>
                    </a>
                  </div>
                </div>
              ))}
            </div>
          )}
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
