---
import BaseLayout from '../layouts/BaseLayout.astro';
import playlists from '../content/videos/playlists.json';

const API_KEY = String(import.meta.env.YOUTUBE_API_KEY).trim();
const response = await fetch(url, {
  headers: {
    'Referer': 'https://elevatewithandy.com'
  }
});
const structuredCategories = await Promise.all(
  playlists.map(async (pl) => {
    let videos = [];
    
    try {
      const url = `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&maxResults=3&playlistId=${pl.id}&key=${API_KEY}`;
      
      const response = await fetch(url);
      
      if (response.ok) {
        const data = await response.json();
        
        videos = (data.items || []).map((item: any) => {
          const videoId = item.snippet?.resourceId?.videoId || '';
          return {
            title: item.snippet?.title || 'Movement Session',
            youtubeUrl: `https://youtube.com/watch?v=${videoId}&list=${pl.id}`,
            thumbnail: item.snippet?.thumbnails?.maxres?.url || 
                      item.snippet?.thumbnails?.high?.url || 
                      `https://youtube.com{videoId}/maxresdefault.jpg`
          };
        });
      } else {
        const errData = await response.json();
        console.error(`Google API Error for ${pl.name}:`, errData.error?.message);
      }
    } catch (e) {
      console.error(`Network error reaching Google API for ${pl.name}:`, e);
    }

    return {
      name: pl.name,
      description: pl.description,
      videos: videos
    };
  })
);
---
<BaseLayout title="Movement Index | Elevate With Andy">
  <main class="max-w-5xl mx-auto px-6 py-16 w-full">
    
    <!-- Header Title Section -->
    <div class="text-center max-w-xl mx-auto mb-20">
      <h1 class="text-3xl font-light tracking-wide text-[#1e1b21] uppercase">On-Demand Practice</h1>
      <p class="text-sm text-[#7a7480] mt-3 font-light leading-relaxed">
        Sequences and training sets sorted by movement discipline.
      </p>
    </div>

    <!-- Playlist Category Grid Blocks -->
    <div class="space-y-24 w-full block">
      {structuredCategories.map(category => (
        <section class="w-full block clear-both">
          
          <!-- Category Headings -->
          <div class="border-b border-neutral-100 pb-4 mb-8 block w-full">
            <h2 class="text-xs font-bold tracking-widest text-[#7a7480] uppercase">
              {category.name}
            </h2>
            <p class="text-xs text-[#7a7480] font-light mt-2 max-w-2xl leading-relaxed whitespace-pre-line">
              {category.description}
            </p>
          </div>
          
          <!-- Content Display Control Matrix -->
          {category.videos.length === 0 ? (
            <div class="py-12 px-6 border border-dashed border-neutral-200 rounded-lg max-w-sm block clear-both">
              <p class="text-xs text-[#7a7480] font-light italic">
                New movement sequences coming soon to this collection.
              </p>
            </div>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full block">
              {category.videos.map(video => (
                <a 
                  href={video.youtubeUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="group block bg-white border border-neutral-100 rounded-lg p-4 shadow-sm hover:border-[#7a7480]/20 transition-all cursor-pointer"
                >
                  <div class="aspect-video w-full overflow-hidden bg-neutral-50 rounded mb-4">
                    <img 
                      src={video.thumbnail} 
                      alt={video.title} 
                      loading="lazy"
                      class="w-full h-full object-cover transition-all duration-300 group-hover:scale-[1.02]"
                    />
                  </div>
                  <h3 class="font-normal text-base text-[#1e1b21] leading-snug line-clamp-2 transition-colors group-hover:text-[#7a7480]">
                    {video.title}
                  </h3>
                </a>
              ))}
            </div>
          )}
        </section>
      ))}
    </div>
  </main>
</BaseLayout>