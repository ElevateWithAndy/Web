---
import Parser from 'rss-parser';
import BaseLayout from '../layouts/BaseLayout.astro';

const parser = new Parser();

const playlists = [
  {
    name: "Pilates Cookies | Bite-Sized Resets",
    id: "PL-jCamkYihtuEjomINLE9siPYAxrijcPg",
    description: `Enjoy a Pilates Cookie — a bite-sized movement ritual...`
  },
  {
    name: "Shadows & Stars: The Wild Experiment",
    id: "PL-jCamkYihtt3kq88Pfi1-ZlaBi0AOpO2",
    description: `Welcome to a space where thriving is a wild experiment...`
  }
];

// Helper function to stop the request if YouTube hangs or stalls
const fetchWithTimeout = async (url: string, timeout = 4000) => {
  const controller = new AbortController();
  const id = setTimeout(() => controller.abort(), timeout);
  try {
    const response = await fetch(url, { signal: controller.signal });
    clearTimeout(id);
    return response;
  } catch (err) {
    clearTimeout(id);
    throw err;
  }
};

// 🛠 FIX 1: Swapped to 'allSettled' so if one playlist fails, the others still build
const playlistPromises = playlists.map(async (pl) => {
  try {
    // 🛠 FIX 2: Added a timeout so a slow YouTube server won't freeze your site build
    const url = `https://youtube.com{pl.id}`;
    const response = await fetchWithTimeout(url);
    
    if (!response.ok) {
      throw new Error(`YouTube API returned HTTP status ${response.status}`);
    }
    
    const xmlText = await response.text();
    const feed = await parser.parseString(xmlText);
    
    const videos = (feed.items || []).map(item => {
      const videoId = item.id ? item.id.replace('yt:video:', '') : '';
      return {
        title: item.title || 'Movement Session',
        youtubeUrl: item.link || `https://youtube.com{videoId}`,
        thumbnail: videoId 
          ? `https://youtube.com{videoId}/maxresdefault.jpg` 
          : 'https://youtube.com'
      };
    }).slice(0, 3);

    return { name: pl.name, description: pl.description, videos };
  } catch (e) {
    // 🛠 FIX 3: Silently log the issue to your console, but gracefully return an empty state
    console.error(`❌ [YouTube Sync Error] Failed to load "${pl.name}":`, e.message);
    return { name: pl.name, description: pl.description, videos: [] };
  }
});

const results = await Promise.allSettled(playlistPromises);

// 🛠 FIX 4: Unpack the settled elements and guarantee your page always receives an array
const structuredCategories = results.map((result, index) => {
  if (result.status === 'fulfilled') {
    return result.value;
  }
  // Ultimate backup fallback if the entire inner block threw an unhandled error
  return { 
    name: playlists[index].name, 
    description: playlists[index].description, 
    videos: [] 
  };
});
---
