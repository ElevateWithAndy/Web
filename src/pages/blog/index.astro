---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch the entries safely with fallback array tracking
const rawPosts = await getCollection('blog') || [];
const posts = rawPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Journal | Elevate With Andy">
  <main class="max-w-3xl mx-auto px-6 py-16">
    <div class="mb-16">
      <h1 class="text-3xl font-light tracking-wide text-[#1e1b21] uppercase">The Journal</h1>
      <p class="text-sm text-[#7a7480] mt-2 font-light">Insights on movement, anatomy, and stability practice.</p>
    </div>

    <div class="space-y-12">
      {posts.map(post => (
        <article class="group border-b border-neutral-100 pb-10 last:border-0">
          <div class="flex items-center gap-4 text-xs text-[#7a7480]">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-us', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </div>
          
          <h2 class="text-xl font-normal text-[#1e1b21] mt-3 group-hover:text-[#7a7480] transition-colors">
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h2>
          
          <p class="text-sm text-[#7a7480] font-light mt-2 leading-relaxed max-w-2xl">
            {post.data.description}
          </p>
          
          <div class="mt-4">
            <a href={`/blog/${post.slug}/`} class="text-xs font-semibold tracking-wider uppercase text-[#1e1b21] hover:underline">
              Read Entry →
            </a>
          </div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
