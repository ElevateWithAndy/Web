---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = Object.values(import.meta.glob('./*.md', { eager: true }))
  .map((post) => ({
    ...post.frontmatter,
    url: post.url,
  }))
  .sort((a, b) => new Date(b.date) - new Date(a.date));
---

<BaseLayout title="Blog" description="Blog posts and stories.">
  <section class="card">
    <h2>Blog</h2>
    <p>Curated posts from the Elevate with Andy blog.</p>
    <ul>
      {posts.map((post) => (
        <li>
          <a href={post.url}>{post.title}</a>
          <span> — {post.date}</span>
          <p>{post.description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

