---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('LivingNotebook') || [];
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

// 🌟 UPDATED: Defaults cleanly to 'elevate' layout parameters if missing in frontmatter
const layoutType = post.data.layoutType || 'elevate';

// 🌟 UPDATED: Renamed variable array block to elevateStyles to match your target brand
const elevateStyles = `
  [&_h2]:text-base [&_h2]:font-normal [&_h2]:uppercase [&_h2]:tracking-wider [&_h2]:text-[#1e1b21] [&_h2]:pt-6
  [&_h3]:text-sm [&_h3]:font-medium [&_h3]:text-[#7a7480] [&_h3]:pt-4
  [&_p]:leading-relaxed [&_p]:text-neutral-700
  [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-2 [&_ul]:text-neutral-600
  [&_blockquote]:border-l-2 [&_blockquote]:border-[#7a7480] [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-[#7a7480] [&_blockquote]:my-6
`;

const dndStyles = `
  font-serif
  [&_h2]:text-xl [&_h2]:font-bold [&_h2]:font-serif [&_h2]:text-amber-900 [&_h2]:border-b [&_h2]:border-amber-100 [&_h2]:pb-1 [&_h2]:pt-8
  [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-amber-800 [&_h3]:pt-4
  [&_p]:leading-relaxed [&_p]:text-neutral-800 [&_p]:tracking-wide
  [&_ul]:list-square [&_ul]:pl-5 [&_ul]:space-y-2 [&_ul]:text-neutral-700
  [&_strong]:font-bold [&_strong]:text-amber-900
  [&_blockquote]:bg-amber-50/50 [&_blockquote]:border-l-4 [&_blockquote]:border-amber-600 [&_blockquote]:p-4 [&_blockquote]:rounded-r [&_blockquote]:italic [&_blockquote]:text-amber-900 [&_blockquote]:my-6
`;
---

<BaseLayout title={`${post.data.title} | Elevate With Andy`}>
  <main class="max-w-2xl mx-auto px-6 py-20">
    
    <!-- Navigation Layer -->
    <nav class="mb-16">
      <a href="/LivingNotebook" class="text-xs font-semibold tracking-widest uppercase text-[#7a7480] hover:text-[#1e1b21] inline-flex items-center gap-2 transition-colors group">
        <span class="text-sm transform group-hover:-translate-x-1 transition-transform">←</span> 
        Back to Living Notebook
      </a>
    </nav>
    
    <article class={layoutType === 'dnd' ? 'font-serif' : 'font-sans'}>
      <header class="mb-12 pb-8 border-b border-neutral-100">
        <time class="text-xs text-[#7a7480] tracking-widest font-medium uppercase block mb-3">
          {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class={`text-3xl font-light leading-snug uppercase tracking-wide max-w-xl ${layoutType === 'dnd' ? 'text-amber-900 font-serif' : 'text-[#1e1b21]'}`}>
          {post.data.title}
        </h1>
        {post.data.description && (
          <p class="text-sm text-[#7a7480] font-light italic mt-4 leading-relaxed">{post.data.description}</p>
        )}
      </header>

      <!-- 🌟 UPDATED: Dynamic matrix container flags elevateStyles wrapper rules natively -->
      <div class={`text-sm text-[#1e1b21] space-y-6 ${layoutType === 'dnd' ? dndStyles : elevateStyles}`}>
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
