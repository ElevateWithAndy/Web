---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 🌟 LOCKED IN: Explicitly targets your active 'LivingNotebook' collection database key
export async function getStaticPaths() {
  const posts = await getCollection('LivingNotebook') || [];
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

const layoutType = post.data.layoutType || 'elevate';

// ELEVATE THEME: Premium, clean minimalist editorial design
const elevateStyles = `
  prose prose-neutral max-w-none font-sans text-sm text-[#1e1b21] leading-relaxed
  prose-headings:uppercase prose-headings:tracking-wider prose-headings:font-light prose-headings:text-[#1e1b21]
  prose-h2:text-base prose-h2:pt-4
  prose-h3:text-sm prose-h3:text-[#7a7480]
  prose-p:text-neutral-700 prose-p:font-light
  prose-blockquote:border-l-2 prose-blockquote:border-[#7a7480] prose-blockquote:text-[#7a7480] prose-blockquote:font-light prose-blockquote:italic
  prose-ul:list-disc
`;

// D&D THEME: Fantasy novel formatting with active borders and custom list shapes
const dndStyles = `
  prose prose-stone max-w-none font-serif text-base text-neutral-900 leading-relaxed
  prose-headings:font-serif prose-headings:text-amber-900 prose-headings:font-bold
  prose-h2:text-xl prose-h2:border-b prose-h2:border-amber-200 prose-h2:pb-1 prose-h2:pt-6
  prose-h3:text-base prose-h3:text-amber-800
  prose-p:text-neutral-800
  prose-blockquote:bg-amber-50/50 prose-blockquote:border-l-4 prose-blockquote:border-amber-600 prose-blockquote:p-4 prose-blockquote:rounded-r prose-blockquote:italic prose-blockquote:text-amber-900
  prose-ul:list-inside
`;
---

<BaseLayout title={`${post.data.title} | Elevate With Andy`}>
  <main class="max-w-2xl mx-auto px-6 py-20">
    
    <!-- Navigation Layer -->
    <nav class="mb-16">
      <a href="/LivingNotebook" class="text-xs font-semibold tracking-widest uppercase text-[#7a7480] hover:text-[#1e1b21] inline-flex items-center gap-2 transition-colors group">
        <span class="text-sm transform group-hover:-translate-x-1 transition-transform">←</span> 
        Back to Living Notebook
      </a>
    </nav>
    
    <article>
      <header class="mb-12 pb-8 border-b border-neutral-100">
        <time class="text-xs text-[#7a7480] tracking-widest font-medium uppercase block mb-3">
          {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class={`text-3xl font-light leading-snug uppercase tracking-wide max-w-xl ${layoutType === 'dnd' ? 'text-amber-900 font-serif' : 'text-[#1e1b21]'}`}>
          {post.data.title}
        </h1>
        {post.data.description && (
          <p class="text-sm text-[#7a7480] font-light italic mt-4 leading-relaxed">{post.data.description}</p>
        )}
      </header>

      <!-- Dynamic typography container using our verified style classes -->
      <div class={layoutType === 'dnd' ? dndStyles : elevateStyles}>
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  /* Specifically forces list elements inside D&D pages to stay square */
  .prose-stone ul {
    list-style-type: square !important;
  }
</style>