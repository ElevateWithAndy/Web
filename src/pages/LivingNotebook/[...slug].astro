---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('LivingNotebook');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'LivingNotebook'>;

const post = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} | Elevate With Andy`}>
  <main class="max-w-2xl mx-auto px-6 py-16">
    <nav class="mb-12">
      <a href="/LivingNotebook" class="text-xs font-semibold tracking-wider uppercase text-[#7a7480] hover:text-[#1e1b21] transition-colors">
        ← Back to Living Notebook
      </a>
    </nav>
    
    <article>
      <header class="mb-10">
        <time class="text-xs text-[#7a7480] tracking-wide block mb-2">
          {post.data.pubDate.toLocaleDateString('en-us', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <h1 class="text-3xl font-light text-[#1e1b21] leading-tight uppercase tracking-wide">{post.data.title}</h1>
      </header>

      <!-- Elegant typography style configurations -->
      <div class="prose prose-neutral max-w-none font-light text-[#1e1b21] leading-relaxed text-sm space-y-6">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
