---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('LivingNotebook') || [];
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

const layoutType = post.data.layoutType || 'elevate';

// 🌟 ELEVATE THEME: Ultra-clean editorial layout with forced styling layers
const elevateStyles = `
  max-w-none font-sans text-sm text-[#1e1b21] leading-relaxed space-y-6
  [&_h2]:text-base [&_h2]:font-normal [&_h2]:uppercase [&_h2]:tracking-wider [&_h2]:text-[#1e1b21] [&_h2]:pt-6 [&_h2]:block
  [&_h3]:text-sm [&_h3]:font-medium [&_h3]:text-[#7a7480] [&_h3]:pt-4 [&_h3]:block
  [&_p]:leading-relaxed [&_p]:text-neutral-700
  [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-2 [&_ul]:text-neutral-600
  [&_blockquote]:border-l-2 [&_blockquote]:border-[#7a7480] [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-[#7a7480] [&_blockquote]:my-6
`;

// 🌟 D&D THEME: Fantasy novel layout with explicit, forced borders and background blocks
const dndStyles = `
  max-w-none font-serif text-base text-neutral-900 leading-relaxed space-y-6
  [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-[#78350f] [&_h2]:border-b [&_h2]:border-[#b45309]/30 [&_h2]:pb-2 [&_h2]:pt-8 [&_h2]:block
  [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-[#92400e] [&_h3]:pt-4 [&_h3]:block
  [&_p]:leading-relaxed [&_p]:text-neutral-800
  [&_ul]:list-inside [&_ul]:pl-5 [&_ul]:space-y-2 [&_ul]:text-neutral-700
  [&_strong]:font-bold [&_strong]:text-[#78350f]
  [&_blockquote]:bg-[#fefbe8] [&_blockquote]:border-l-4 [&_blockquote]:border-[#b45309] [&_blockquote]:p-5 [&_blockquote]:rounded-r [&_blockquote]:italic [&_blockquote]:text-[#78350f] [&_blockquote]:my-6 [&_blockquote]:block [&_blockquote]:shadow-sm
`;
---

<BaseLayout title={`${post.data.title} | Elevate With Andy`}>
  <main class="max-w-2xl mx-auto px-6 py-20">
    
    <!-- Navigation Layer -->
    <nav class="mb-16">
      <a href="/LivingNotebook" class="text-xs font-semibold tracking-widest uppercase text-[#7a7480] hover:text-[#1e1b21] inline-flex items-center gap-2 transition-colors group">
        <span class="text-sm transform group-hover:-translate-x-1 transition-transform">←</span> 
        Back to Living Notebook
      </a>
    </nav>
    
    <article>
      <header class="mb-12 pb-8 border-b border-neutral-100">
        <time class="text-xs text-[#7a7480] tracking-widest font-medium uppercase block mb-3">
          {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class={`text-3xl font-light leading-snug uppercase tracking-wide max-w-xl ${layoutType === 'dnd' ? 'text-[#78350f] font-serif' : 'text-[#1e1b21] font-sans'}`}>
          {post.data.title}
        </h1>
        {post.data.description && (
          <p class="text-sm text-[#7a7480] font-light italic mt-4 leading-relaxed">{post.data.description}</p>
        )}
      </header>

      <!-- Dynamic typography container using our explicit style variables -->
      <div class={layoutType === 'dnd' ? dndStyles : elevateStyles}>
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  /* Explicitly targets and structures list formats across D&D article instances */
  .font-serif ul {
    list-style-type: square !important;
    padding-left: 1.25rem !important;
  }
</style>
