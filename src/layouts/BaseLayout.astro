---
import Header from '../components/Header.astro';
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-neutral-900 font-sans">
    
    <!-- Placing it here automatically renders it on EVERY page that uses this layout -->
    <Header /> 
    
    <slot /> <!-- This is where your page content injects -->
    
  </body>
</html>
