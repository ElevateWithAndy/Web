---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro'; 
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
    <!-- 2. UPDATE BODY CLASSES: We add 'flex flex-col min-h-screen' -->
  <body class="bg-[#fcfbfc] text-[#1e1b21] font-sans flex flex-col min-h-screen">

    <Header />

    <!-- 3. WRAP SLOT IN FLEX-GROW: Pushes the footer down on pages with short text content -->
    <div class="flex-grow">
      <slot />
    </div>

    <!-- 4. ADD THE FOOTER TAG HERE: It anchors safely at the bottom of the page viewport -->
    <Footer />
        <!-- 🌟 FLOATING WATERMARK BANNER CONTAINER -->
    <!-- This creates an elegant, non-intrusive indicator locked in the bottom-right corner -->
    <div class="fixed bottom-4 right-4 z-50 bg-[#1e1b21] border border-neutral-800 text-white/90 text-[10px] tracking-[0.15em] uppercase font-semibold px-4 py-2 rounded shadow-md pointer-events-none select-none backdrop-blur-sm opacity-85 hover:opacity-100 transition-opacity duration-300">
      Site Under Construction
    </div>
</html>
